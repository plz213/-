.login-tip {
  background-color: #FFF3E0;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.tip-text {
  font-size: 32rpx;
  color: #FF9800;
}

.tab-bar {
  display: flex;
  background-color: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 32rpx;
  color: #666666;
  position: relative;
}

.tab-item.active {
  color: #FF9966;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background-color: #FF9966;
}

.food-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.food-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
}

.food-info {
  flex: 1;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  display: block;
}

.food-detail {
  font-size: 24rpx;
  color: #666666;
}

.food-time {
  font-size: 24rpx;
  color: #999999;
}

.btn-delete {
  background-color: #FFF3E0;
  color: #FF9800;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.add-btn-container {
  margin-bottom: 20rpx;
}

.btn-add {
  background-color: #FF9966;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.add-icon {
  font-size: 40rpx;
  font-weight: bold;
}

/* 添加菜品弹窗（覆盖全局 modal 默认样式） */
.modal-content {
  background-color: white;
  border-radius: 16rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.modal-close {
  font-size: 48rpx;
  color: #999999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-body {
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
}

.image-upload {
  border: 2rpx dashed #EEEEEE;
  border-radius: 8rpx;
  padding: 40rpx;
  text-align: center;
}

.uploaded-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.upload-btn {
  background-color: #F5F5F5;
  color: #666666;
  border: none;
  border-radius: 8rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
}

.picker-text {
  border: 1rpx solid #EEEEEE;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 32rpx;
  color: #333333;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 32rpx;
  border-top: 1rpx solid #EEEEEE;
}

.modal-footer .btn-cancel,
.modal-footer .btn-confirm {
  flex: 1;
}
