<view class="container">
  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-section">
      <text class="filter-title">主食类型</text>
      <view class="filter-options">
        <text class="filter-option {{stapleIndex === 0 ? 'active' : ''}}" bindtap="selectStaple" data-index="0">未选择</text>
        <text class="filter-option {{stapleIndex === 1 ? 'active' : ''}}" bindtap="selectStaple" data-index="1">饭</text>
        <text class="filter-option {{stapleIndex === 2 ? 'active' : ''}}" bindtap="selectStaple" data-index="2">面</text>
        <text class="filter-option {{stapleIndex === 3 ? 'active' : ''}}" bindtap="selectStaple" data-index="3">馒头</text>
        <text class="filter-option {{stapleIndex === 4 ? 'active' : ''}}" bindtap="selectStaple" data-index="4">包子</text>
        <text class="filter-option {{stapleIndex === 5 ? 'active' : ''}}" bindtap="selectStaple" data-index="5">其他</text>
      </view>
    </view>
    
    <view class="filter-section">
      <text class="filter-title">食材</text>
      <view class="filter-options">
        <text class="filter-option {{ingredientIndex === 0 ? 'active' : ''}}" bindtap="selectIngredient" data-index="0">未选择</text>
        <text class="filter-option {{ingredientIndex === 1 ? 'active' : ''}}" bindtap="selectIngredient" data-index="1">鸡肉</text>
        <text class="filter-option {{ingredientIndex === 2 ? 'active' : ''}}" bindtap="selectIngredient" data-index="2">猪肉</text>
        <text class="filter-option {{ingredientIndex === 3 ? 'active' : ''}}" bindtap="selectIngredient" data-index="3">牛肉</text>
        <text class="filter-option {{ingredientIndex === 4 ? 'active' : ''}}" bindtap="selectIngredient" data-index="4">鱼</text>
        <text class="filter-option {{ingredientIndex === 5 ? 'active' : ''}}" bindtap="selectIngredient" data-index="5">鸡蛋</text>
        <text class="filter-option {{ingredientIndex === 6 ? 'active' : ''}}" bindtap="selectIngredient" data-index="6">青菜</text>
        <text class="filter-option {{ingredientIndex === 7 ? 'active' : ''}}" bindtap="selectIngredient" data-index="7">土豆</text>
        <text class="filter-option {{ingredientIndex === 8 ? 'active' : ''}}" bindtap="selectIngredient" data-index="8">胡萝卜</text>
        <text class="filter-option {{ingredientIndex === 9 ? 'active' : ''}}" bindtap="selectIngredient" data-index="9">黄瓜</text>
        <text class="filter-option {{ingredientIndex === 10 ? 'active' : ''}}" bindtap="selectIngredient" data-index="10">番茄</text>
        <text class="filter-option {{ingredientIndex === 11 ? 'active' : ''}}" bindtap="selectIngredient" data-index="11">香菇</text>
      </view>
    </view>
    
    <view class="filter-section">
      <text class="filter-title">做法</text>
      <view class="filter-options">
        <text class="filter-option {{methodIndex === 0 ? 'active' : ''}}" bindtap="selectMethod" data-index="0">未选择</text>
        <text class="filter-option {{methodIndex === 1 ? 'active' : ''}}" bindtap="selectMethod" data-index="1">炒</text>
        <text class="filter-option {{methodIndex === 2 ? 'active' : ''}}" bindtap="selectMethod" data-index="2">煮</text>
        <text class="filter-option {{methodIndex === 3 ? 'active' : ''}}" bindtap="selectMethod" data-index="3">蒸</text>
        <text class="filter-option {{methodIndex === 4 ? 'active' : ''}}" bindtap="selectMethod" data-index="4">炖</text>
        <text class="filter-option {{methodIndex === 5 ? 'active' : ''}}" bindtap="selectMethod" data-index="5">煎</text>
      </view>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="btn-primary" bindtap="startRandom">开始抽取</button>
    <button class="btn-secondary" bindtap="resetFilter">重置条件</button>
  </view>
  
  <!-- 结果展示 -->
  <view class="result" wx:if="{{result}}">
    <view class="result-card">
      <image class="result-image" src="{{result.pic}}" mode="aspectFill"></image>
      <view class="result-info">
        <text class="result-name">{{result.name}}</text>
        <text class="result-description" wx:if="{{result.description}}">{{result.description}}</text>
        <text class="result-detail">主食：{{result.staple}}</text>
        <text class="result-detail">做法：{{result.method}}</text>
        <text class="result-detail">食材：{{result.ingredient}}</text>
      </view>
      <button class="btn-secondary mt-20" bindtap="changeFood">换一个</button>
    </view>
  </view>
</view>